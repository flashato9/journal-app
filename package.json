{
  "name": "journal-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "build:generate-icons": "npx ts-node --esm --transpileOnly scripts/generate-icons.ts >nul 2>&1",
    "build:typecheck": "tsc --noEmit",
    "build:lint": "eslint --fix --quiet . && expo lint",
    "build:format": "prettier --write --log-level=silent .",
    "build": "npm run build:typecheck && npm run build:lint && npm run build:format && npm run build:generate-icons",
    "dev": "npm run build && npm run start -- --clear",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "date-fns": "^4.4.0",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-media-library": "^18.2.1",
    "expo-notifications": "^0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-web-browser": "~15.0.11",
    "geolib": "^3.3.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
